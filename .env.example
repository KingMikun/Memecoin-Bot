# --- Telegram ---
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_ALERT_CHAT_ID=your_chat_or_channel_id

# --- Database ---
# Local dev defaults to SQLite. On Railway, add a Postgres plugin and it
# auto-injects DATABASE_URL — just leave this as-is and it upgrades itself.
DATABASE_URL=sqlite:///./king_wallet_bot.db

# --- Solana (Helius) ---
HELIUS_API_KEY=your_helius_api_key
HELIUS_WEBHOOK_SECRET=set_a_random_string_and_verify_it_on_incoming_requests

# --- EVM chains (Alchemy) — covers Ethereum, Base, Robinhood Chain ---
ALCHEMY_API_KEY=your_alchemy_api_key
ALCHEMY_WEBHOOK_SIGNING_KEY=from_alchemy_dashboard

# --- Security / honeypot checks ---
GOPLUS_API_KEY=your_goplus_key
GOPLUS_API_SECRET=your_goplus_secret

# --- Public URL Railway assigns you, used to register webhooks ---
PUBLIC_BASE_URL=https://your-app.up.railway.app

# --- Scoring thresholds (tune freely) ---
MIN_CONFLUENCE_WALLETS=2
CONFLUENCE_WINDOW_MINUTES=15
MAX_TOP10_HOLDER_PCT=60
MIN_LIQUIDITY_USD=3000
